# ── Application ─────────────────────────────────────────────
APP_ENV=local
APP_NAME=azure-agentic-ai-masterclass
LOG_LEVEL=INFO

# ── Azure OpenAI / Foundry ─────────────────────────────────
# Leave AZURE_OPENAI_ENDPOINT empty to run the app in MOCK mode (no Azure needed).
AZURE_OPENAI_ENDPOINT=
AZURE_OPENAI_API_KEY=
AZURE_OPENAI_DEPLOYMENT=gpt-4o
AZURE_OPENAI_API_VERSION=2024-10-21

# ── Grounding / State (used from Week 4+) ──────────────────
AZURE_AI_SEARCH_ENDPOINT=
AZURE_AI_SEARCH_KEY=
COSMOS_CONNECTION_STRING=
REDIS_CONNECTION_STRING=

# ── Identity / Security (used from Week 11) ────────────────
AZURE_TENANT_ID=
AZURE_CLIENT_ID=
KEY_VAULT_URI=
